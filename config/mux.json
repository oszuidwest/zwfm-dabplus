{
    "_comment": "This is the same as example.mux, but in JSON format. JSON doesn't really support comments, so please refer to the example.mux and advanced.mux for documentation of the settings",
    "general": {
        "dabmode": 1,
        "nbframes": 0,
        "syslog": false,
        "tist": false,
        "tist_offset": 0,
        "managementport": 12720
    },
    "remotecontrol": {
        "telnetport": 12721,
        "zmqendpoint": "tcp://lo:12722"
    },
    "ensemble": {
        "id": "0x4fff",
        "ecc": "0xe1",
        "local-time-offset": "auto",
        "reconfig-counter": "hash",
        "label": "OpenDigitalRadio",
        "shortlabel": "ODR"
    },
    "services": {
        "srv-zuidwest": {
            "id": "0x038b",
            "label": "ZuidWest FM",
            "shortlabel": "ZuidWest"
        },
        "srv-slos": {
            "id": "0x4484",
            "label": "SLOS Steenbergen",
            "shortlabel": "SLOS"
        },
        "srv-tholen": {
            "id": "0x833d",
            "label": "Omroep Tholen",
            "shortlabel": "Tholen"
        },
        "srv-rucphen": {
            "id": "0xd5c3",
            "label": "Radio Rucphen",
            "shortlabel": "Rucphen"
        }
    },
    "subchannels": {
        "sub-zuidwest": {
            "type": "dabplus",
            "bitrate": 96,
            "id": 1,
            "protection": 3,
            "inputproto": "edi",
            "inputuri": "tcp://0.0.0.0:7000"
        },
        "sub-slos": {
            "type": "dabplus",
            "bitrate": 96,
            "id": 2,
            "protection": 3,
            "inputproto": "edi",
            "inputuri": "tcp://0.0.0.0:7010"
        },
        "sub-tholen": {
            "type": "dabplus",
            "bitrate": 96,
            "id": 3,
            "protection": 3,
            "inputproto": "edi",
            "inputuri": "tcp://0.0.0.0:7020"
        },
        "sub-rucphen": {
            "type": "dabplus",
            "bitrate": 96,
            "id": 4,
            "protection": 3,
            "inputproto": "edi",
            "inputuri": "tcp://0.0.0.0:7030"
        }
    },
    "components": {
        "comp-zuidwest": {
            "service": "srv-zuidwest",
            "subchannel": "sub-zuidwest",
            "user-applications": {
                "userapp": "slideshow"
            }
        },
        "comp-slos": {
            "service": "srv-slos",
            "subchannel": "sub-slos"
        },
        "comp-tholen": {
            "service": "srv-tholen",
            "subchannel": "sub-tholen",
            "user-applications": {
                "userapp": "slideshow"
            }
        },
        "comp-rucphen": {
            "service": "srv-rucphen",
            "subchannel": "sub-rucphen"
        }
    },
    "outputs": {
        "throttle": "simul://",
        "edi": {
            "destinations": {
                "example_tcp": {
                    "protocol": "tcp",
                    "listenport": 13000
                }
            }
        }
    }
}