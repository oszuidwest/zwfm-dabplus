[Unit]
Description=DAB+ Multiplexer
After=network.target
Documentation=https://github.com/oszuidwest/rpi-umpx-decoder

[Service]
Type=simple
ExecStart=odr-dabmux /var/dab/mux/mux.json
Restart=always
StandardOutput=file:/var/log/dab/mux/dabmux.log
StandardError=file:/var/log/dab/mux/dabmux.err

[Install]
WantedBy=multi-user.target
Alias=dabmux.service
